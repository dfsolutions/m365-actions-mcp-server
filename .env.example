# Azure AD / Entra ID App Registration
M365_CLIENT_ID=your-client-id-here
M365_CLIENT_SECRET=your-client-secret-here
M365_TENANT_ID=your-tenant-id-here
M365_REDIRECT_URI=http://localhost:3939/auth/callback

# User email (required for client_credentials flow to specify the mailbox)
# Not needed for delegated auth, but useful as fallback
M365_USER_EMAIL=
